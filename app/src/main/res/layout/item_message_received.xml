<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <TextView
        android:id="@+id/date_divider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="2dp"
        android:textColor="#888888"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/message_profile_image"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_profile"
        app:layout_constraintBottom_toBottomOf="@+id/message_bubble"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/message_bubble"
        app:shapeAppearanceOverlay="@style/CircleImageView" />

    <LinearLayout
        android:id="@+id/message_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/received_message_background"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@+id/btn_reply"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/message_profile_image"
        app:layout_constraintTop_toBottomOf="@+id/date_divider"
        app:layout_constraintWidth_max="280dp">

        <TextView
            android:id="@+id/sender_name_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:textColor="#FF8A65"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/reply_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="#1A000000"
            android:orientation="vertical"
            android:padding="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/reply_sender_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#0088CC"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/reply_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#66000000"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/message_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:textSize="16sp" />

        <include layout="@layout/layout_voice_bubble" />
        <TextView
            android:id="@+id/edited_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="edited"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:textStyle="italic"
            android:visibility="gone" />
        <TextView
            android:id="@+id/time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginTop="2dp"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_reply"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="4dp"
        android:alpha="0.5"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintBottom_toBottomOf="@+id/message_bubble"
        app:layout_constraintStart_toEndOf="@+id/message_bubble"
        app:layout_constraintTop_toTopOf="@+id/message_bubble"
        app:tint="@android:color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>
